# Application
SERVER_PORT=9090
SPRING_PROFILES_ACTIVE=dev

# Database
DB_URL=jdbc:postgresql://localhost:5432/quizze
DB_USERNAME=postgres
DB_PASSWORD=postgres

# JWT
JWT_SECRET=replace-with-a-secure-base64-secret
JWT_EXPIRATION=86400000

# Mail
APP_MAIL_ENABLED=false
APP_MAIL_FROM_ADDRESS=no-reply@quizze.local
APP_MAIL_FROM_NAME=Quizze
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# Redis
APP_CACHE_REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Kafka
APP_KAFKA_LISTENERS_ENABLED=false
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# New Quiz Notifications
APP_NOTIFICATIONS_NEW_QUIZ_ENABLED=false
APP_NOTIFICATIONS_NEW_QUIZ_TOPIC=quizze.new-quiz.published
APP_NOTIFICATIONS_NEW_QUIZ_GROUP_ID=quizze-new-quiz-mailer
APP_NOTIFICATIONS_NEW_QUIZ_BATCH_SIZE=100
APP_NOTIFICATIONS_NEW_QUIZ_MAX_RETRY_ATTEMPTS=3

# Quiz Result Notifications
APP_NOTIFICATIONS_QUIZ_RESULT_ENABLED=false
APP_NOTIFICATIONS_QUIZ_RESULT_TOPIC=quizze.quiz-submitted
APP_NOTIFICATIONS_QUIZ_RESULT_GROUP_ID=quizze-quiz-result-mailer
APP_NOTIFICATIONS_QUIZ_RESULT_MAX_RETRY_ATTEMPTS=3
